# name: test/sql/subtree.test
# group: [vgi_reghive]
#
# hive_subtree() scopes the §5 scan to a subtree. A VGI table function cannot take
# a column/subquery argument, so the hive BLOB is supplied as an unhex() literal
# (the SYSTEM fixture, baked in below). read_hive(BLOB) is exercised the same way.

require-env VGI_REGHIVE_WORKER

statement ok
LOAD vgi;

statement ok
ATTACH 'reghive' AS reghive (TYPE vgi, LOCATION '${VGI_REGHIVE_WORKER}');

statement ok
SET search_path = 'reghive.main';

# Scope to the Services subtree: every emitted row is at/under it.
query I
SELECT count(*) = count(*) FILTER (WHERE key_path LIKE 'ControlSet001\Services%')
FROM hive_subtree(unhex(''), 'ControlSet001\Services');
----
true

# The scoped scan still decodes values correctly.
query TT
SELECT value_name, value_data
FROM hive_subtree(unhex(''), 'ControlSet001\Services\Schedule')
WHERE value_name = 'Start';
----
Start	3

# read_hive(BLOB): the same SYSTEM hive as an in-memory blob yields rows.
query I
SELECT count(*) > 0
FROM read_hive(unhex(''));
----
true

statement ok
USE memory;

statement ok
DETACH reghive;
